PORT=8790
ADMIN_API_KEY=change-me-to-a-long-secret
# Comma-separated origins allowed to call POST /verify-license (your POS sites)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
DATABASE_PATH=./data/licenses.db

# Deploy on your VPS:
# 1) Copy this folder to the server, run: npm install && npm run build
# 2) Set ADMIN_API_KEY and CORS_ORIGIN to your real POS URL(s)
# 3) Start: node dist/index.js  (or pm2)
# 4) AdminPOS server/.env: LICENSE_SERVER_URL=https://license-server-production-751a.up.railway.app
# 5) AdminPOS client: VITE_LICENSE_ADMIN_URL=https://license-server-production-751a.up.railway.app/
# 5) Open https://licencias.yourdomain.com/ to manage all machines

# --- Railway ---
# In Railway → Variables, set:
#   ADMIN_API_KEY = (long secret)
#   CORS_ORIGIN = https://your-pos-site.com  (or http://localhost:5173 for testing)
# Add a Volume mounted at /data (Railway sets RAILWAY_VOLUME_MOUNT_PATH automatically)
# Optional: DATABASE_PATH=/data/licenses.db